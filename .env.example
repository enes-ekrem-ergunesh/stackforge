# General
NODE_ENV=production
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Backend
BACKEND_HOST_PORT=3000

# Frontend
FRONTEND_HOST_PORT=4200

# Database
POSTGRES_DB=stackforge
POSTGRES_USER=stackforge
POSTGRES_PASSWORD=change_me_generate_a_long_random_password
POSTGRES_HOST_PORT=5432

# Backup service
BACKUP_INTERVAL_SECONDS=86400
BACKUP_RETENTION_DAYS=7

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
